// ── Генератор клиента ──────────────────────────────────────
generator client {
  provider        = "prisma-client-js"
  output          = "../../src/generated/client"
}


datasource db {
  provider = "postgresql"
}

// ── COMPANY ────────────────────────────────────────────────
// Верхний уровень. Все заказы и пользователи — внутри компании.
model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  bookings Booking[]
  expenses Expense[]  // для агрегации отчётов
}

// ── USER ───────────────────────────────────────────────────
// MANAGER  — создаёт бронирования от имени компании
// PROVIDER — управляет площадками, получает уведомления
// ADMIN    — полный доступ, модерация

enum Role {
  MANAGER
  PROVIDER
  ADMIN
}

// ── VENUE ──────────────────────────────────────────────────
// Площадка или услуга. pricePerHour нужен для авторасчёта.
model Venue {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     Category
  pricePerHour Decimal  @db.Decimal(10, 2)
  capacity     Int?
  address      String?
  photos       String[]
  tags         String[]
  hours        String?
  duration     String?
  averageCheck String?
  rating       Float?
  menus        Json?

  isActive     Boolean  @default(true)  // модерация admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  

  providerId String
  provider   User     @relation(fields: [providerId], references: [id])

  bookings Booking[]
}

enum Category {
  RESTAURANTS
  OUTDOOR
  MASTER_CLASSES
  ACTIVITIES
  GIFTS
}


// ── BOOKING ────────────────────────────────────────────────
// Одна позиция в Event Basket.
// cost = venue.pricePerHour × (endTime - startTime) в часах
model Booking {
  id        String        @id @default(cuid())
  status    BookingStatus @default(PENDING)
  startTime DateTime
  endTime   DateTime
  guestCount Int?
  cost      Decimal       @db.Decimal(10, 2)
  eventName String?       // название мероприятия
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  managerId String
  manager   User    @relation(fields: [managerId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  venueId   String
  venue     Venue   @relation(fields: [venueId], references: [id])

  expenses   Expense []  // создаётся при CONFIRMED
}

enum BookingStatus {
  PENDING    // ждёт ответа провайдера
  CONFIRMED  // провайдер подтвердил → триггер уведомления
  CANCELLED
}

// ── EXPENSE ────────────────────────────────────────────────
// Автосоздаётся при Booking → CONFIRMED.
// Отдельная таблица для удобной аналитики и отчётов.
// Можно добавить ручные расходы (bookingId будет null).
model Expense {
  id          String   @id @default(cuid())
  amount      Decimal  @db.Decimal(10, 2)
  category    Category
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  // @unique — один Booking даёт ровно один Expense
  bookingId String? 
  booking   Booking? @relation(fields: [bookingId], references: [id])
}
